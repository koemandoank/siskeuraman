// SISKEURAMAN — Prisma Schema
// Mengikuti DATABASE.md. Konvensi:
// - PK: UUID
// - created_at/updated_at: semua tabel
// - deleted_at: soft delete untuk data penting
// - owner_id: pemilik data (untuk RBAC "Data Sendiri")
// - created_by/updated_by: audit pelaku aksi (disimpan sbg UUID string,
//   relasi formal hanya dibuat pada owner_id agar skema tetap ramping;
//   integritas created_by/updated_by dijaga di service layer + activity_logs)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ ENUMS ============

enum Role {
  ADMINISTRATOR
  AYAH
  IBU
  ANAK
}

enum WalletType {
  CASH
  BANK
  EWALLET
  INVESTMENT
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum BillStatus {
  PENDING
  PAID
  OVERDUE
}

enum SavingStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum GoalStatus {
  PLANNING
  PROGRESS
  COMPLETED
  CANCELLED
}

enum GoalPriority {
  LOW
  MEDIUM
  HIGH
}

enum AssetCategory {
  HOUSE
  CAR
  MOTORCYCLE
  LAND
  ELECTRONICS
  GOLD
  JEWELRY
  OTHER
}

enum InvestmentType {
  GOLD
  STOCK
  CRYPTO
  MUTUAL_FUND
  DEPOSIT
  PROPERTY
}

enum DebtStatus {
  ONGOING
  PAID
  OVERDUE
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
  REMINDER
}

enum ActivityAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  RESTORE
  EXPORT
  IMPORT
  BACKUP
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

// ============ MASTER TABLES ============

/// Profile pengguna. id = auth.users.id milik Supabase Auth (bukan default UUID).
model User {
  id        String    @id @db.Uuid
  fullName  String    @map("full_name")
  username  String    @unique
  email     String    @unique
  role      Role      @default(ANAK)
  phone     String?
  avatar    String?
  isActive  Boolean   @default(true) @map("is_active")
  lastLogin DateTime? @map("last_login") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  wallets       Wallet[]
  incomes       Income[]
  expenses      Expense[]
  savings       Saving[]
  goals         Goal[]
  assets        Asset[]
  investments   Investment[]
  debts         Debt[]
  receivables   Receivable[]
  notifications Notification[]
  activityLogs  ActivityLog[]

  @@index([username])
  @@index([email])
  @@map("users")
}

model Category {
  id          String       @id @default(uuid()) @db.Uuid
  type        CategoryType
  name        String
  icon        String?
  color       String?
  description String?
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz

  incomes  Income[]
  expenses Expense[]
  bills    Bill[]

  @@index([type])
  @@map("categories")
}

model Wallet {
  id             String     @id @default(uuid()) @db.Uuid
  ownerId        String     @map("owner_id") @db.Uuid
  walletName     String     @map("wallet_name")
  walletType     WalletType @map("wallet_type")
  accountNumber  String?    @map("account_number")
  bankName       String?    @map("bank_name")
  openingBalance Decimal    @default(0) @map("opening_balance") @db.Decimal(18, 2)
  currentBalance Decimal    @default(0) @map("current_balance") @db.Decimal(18, 2)
  color          String?
  icon           String?
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?  @map("deleted_at") @db.Timestamptz

  owner         User                @relation(fields: [ownerId], references: [id])
  incomes       Income[]
  expenses      Expense[]
  transfersFrom Transfer[]          @relation("TransferFrom")
  transfersTo   Transfer[]          @relation("TransferTo")
  bills         Bill[]
  savingTxns    SavingTransaction[]

  @@index([ownerId])
  @@map("wallets")
}

// ============ TRANSACTION TABLES ============

model Income {
  id                String    @id @default(uuid()) @db.Uuid
  transactionNumber String    @unique @map("transaction_number")
  transactionDate   DateTime  @map("transaction_date") @db.Timestamptz
  ownerId           String    @map("owner_id") @db.Uuid
  categoryId        String    @map("category_id") @db.Uuid
  walletId          String    @map("wallet_id") @db.Uuid
  amount            Decimal   @db.Decimal(18, 2)
  description       String?
  attachment        String?
  createdBy         String    @map("created_by") @db.Uuid
  updatedBy         String?   @map("updated_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz

  owner    User     @relation(fields: [ownerId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])
  wallet   Wallet   @relation(fields: [walletId], references: [id])

  @@index([transactionDate])
  @@index([walletId])
  @@index([categoryId])
  @@index([ownerId])
  @@map("income")
}

model Expense {
  id                String    @id @default(uuid()) @db.Uuid
  transactionNumber String    @unique @map("transaction_number")
  transactionDate   DateTime  @map("transaction_date") @db.Timestamptz
  ownerId           String    @map("owner_id") @db.Uuid
  categoryId        String    @map("category_id") @db.Uuid
  walletId          String    @map("wallet_id") @db.Uuid
  amount            Decimal   @db.Decimal(18, 2)
  merchant          String?
  location          String?
  attachment        String?
  description       String?
  createdBy         String    @map("created_by") @db.Uuid
  updatedBy         String?   @map("updated_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz

  owner    User     @relation(fields: [ownerId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])
  wallet   Wallet   @relation(fields: [walletId], references: [id])

  @@index([transactionDate])
  @@index([walletId])
  @@index([categoryId])
  @@index([ownerId])
  @@map("expense")
}

model Transfer {
  id             String   @id @default(uuid()) @db.Uuid
  transferNumber String   @unique @map("transfer_number")
  fromWalletId   String   @map("from_wallet") @db.Uuid
  toWalletId     String   @map("to_wallet") @db.Uuid
  amount         Decimal  @db.Decimal(18, 2)
  transferDate   DateTime @map("transfer_date") @db.Timestamptz
  description    String?
  createdBy      String   @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  fromWallet Wallet @relation("TransferFrom", fields: [fromWalletId], references: [id])
  toWallet   Wallet @relation("TransferTo", fields: [toWalletId], references: [id])

  @@index([fromWalletId])
  @@index([toWalletId])
  @@map("transfers")
}

model Bill {
  id             String         @id @default(uuid()) @db.Uuid
  categoryId     String         @map("category_id") @db.Uuid
  billName       String         @map("bill_name")
  amount         Decimal        @db.Decimal(18, 2)
  dueDate        DateTime       @map("due_date") @db.Timestamptz
  reminderDays   Int            @default(3) @map("reminder_days")
  recurrenceType RecurrenceType @default(NONE) @map("recurrence_type")
  status         BillStatus     @default(PENDING)
  isPaid         Boolean        @default(false) @map("is_paid")
  paidDate       DateTime?      @map("paid_date") @db.Timestamptz
  walletId       String?        @map("wallet_id") @db.Uuid
  note           String?
  createdBy      String         @map("created_by") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz

  category Category @relation(fields: [categoryId], references: [id])
  wallet   Wallet?  @relation(fields: [walletId], references: [id])

  @@index([dueDate])
  @@index([status])
  @@map("bills")
}

model Saving {
  id            String       @id @default(uuid()) @db.Uuid
  ownerId       String       @map("owner_id") @db.Uuid
  savingName    String       @map("saving_name")
  targetAmount  Decimal      @map("target_amount") @db.Decimal(18, 2)
  currentAmount Decimal      @default(0) @map("current_amount") @db.Decimal(18, 2)
  deadline      DateTime?    @db.Timestamptz
  description   String?
  status        SavingStatus @default(ACTIVE)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz

  owner        User                @relation(fields: [ownerId], references: [id])
  transactions SavingTransaction[]

  @@index([ownerId])
  @@index([status])
  @@map("savings")
}

model SavingTransaction {
  id              String   @id @default(uuid()) @db.Uuid
  savingId        String   @map("saving_id") @db.Uuid
  walletId        String   @map("wallet_id") @db.Uuid
  amount          Decimal  @db.Decimal(18, 2)
  transactionDate DateTime @map("transaction_date") @db.Timestamptz
  note            String?
  createdBy       String   @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  saving Saving @relation(fields: [savingId], references: [id])
  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([savingId])
  @@map("saving_transactions")
}

model Goal {
  id            String       @id @default(uuid()) @db.Uuid
  ownerId       String       @map("owner_id") @db.Uuid
  title         String
  targetAmount  Decimal      @map("target_amount") @db.Decimal(18, 2)
  currentAmount Decimal      @default(0) @map("current_amount") @db.Decimal(18, 2)
  deadline      DateTime?    @db.Timestamptz
  priority      GoalPriority @default(MEDIUM)
  status        GoalStatus   @default(PLANNING)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz

  owner User @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([status])
  @@map("goals")
}

// ============ ASSETS & INVESTMENTS ============

model Asset {
  id            String        @id @default(uuid()) @db.Uuid
  ownerId       String        @map("owner_id") @db.Uuid
  assetName     String        @map("asset_name")
  category      AssetCategory
  purchasePrice Decimal       @map("purchase_price") @db.Decimal(18, 2)
  currentValue  Decimal       @map("current_value") @db.Decimal(18, 2)
  purchaseDate  DateTime      @map("purchase_date") @db.Timestamptz
  description   String?
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime?     @map("deleted_at") @db.Timestamptz

  owner User @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@map("assets")
}

model Investment {
  id             String         @id @default(uuid()) @db.Uuid
  ownerId        String         @map("owner_id") @db.Uuid
  investmentType InvestmentType @map("investment_type")
  investmentName String         @map("investment_name")
  purchaseDate   DateTime       @map("purchase_date") @db.Timestamptz
  purchasePrice  Decimal        @map("purchase_price") @db.Decimal(18, 2)
  currentValue   Decimal        @map("current_value") @db.Decimal(18, 2)
  quantity       Decimal        @default(1) @db.Decimal(18, 4)
  roi            Decimal?       @db.Decimal(9, 4)
  note           String?
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz

  owner User @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([investmentType])
  @@map("investments")
}

// ============ DEBTS & RECEIVABLES ============

model Debt {
  id           String     @id @default(uuid()) @db.Uuid
  ownerId      String     @map("owner_id") @db.Uuid
  creditorName String     @map("creditor_name")
  amount       Decimal    @db.Decimal(18, 2)
  remaining    Decimal    @db.Decimal(18, 2)
  dueDate      DateTime?  @map("due_date") @db.Timestamptz
  interest     Decimal?   @db.Decimal(9, 4)
  status       DebtStatus @default(ONGOING)
  note         String?
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz

  owner User @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@map("debts")
}

model Receivable {
  id         String     @id @default(uuid()) @db.Uuid
  ownerId    String     @map("owner_id") @db.Uuid
  debtorName String     @map("debtor_name")
  amount     Decimal    @db.Decimal(18, 2)
  remaining  Decimal    @db.Decimal(18, 2)
  dueDate    DateTime?  @map("due_date") @db.Timestamptz
  status     DebtStatus @default(ONGOING)
  note       String?
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime?  @map("deleted_at") @db.Timestamptz

  owner User @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@map("receivables")
}

// ============ SYSTEM TABLES ============

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  title     String
  message   String
  type      NotificationType @default(INFO)
  userId    String           @map("user_id") @db.Uuid
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model ActivityLog {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  module    String
  action    ActivityAction
  recordId  String?        @map("record_id") @db.Uuid
  ipAddress String?        @map("ip_address")
  userAgent String?        @map("user_agent")
  oldData   Json?          @map("old_data")
  newData   Json?          @map("new_data")
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@map("activity_logs")
}

model Setting {
  id              String   @id @default(uuid()) @db.Uuid
  companyName     String?  @map("company_name")
  familyName      String?  @map("family_name")
  logo            String?
  currency        String   @default("IDR")
  timezone        String   @default("Asia/Jakarta")
  language        String   @default("id")
  theme           Theme    @default(SYSTEM)
  backupFrequency String?  @map("backup_frequency")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("settings")
}
